{
  "description": "Key API routes in Medusa v2 for incident triage and analysis.",
  "routes": [
    {"method": "POST", "path": "/store/carts", "module": "cart", "description": "Create a new shopping cart"},
    {"method": "GET", "path": "/store/carts/:id", "module": "cart", "description": "Retrieve cart by ID with line items, shipping, and totals"},
    {"method": "POST", "path": "/store/carts/:id", "module": "cart", "description": "Update cart details (email, shipping/billing address, region)"},
    {"method": "POST", "path": "/store/carts/:id/line-items", "module": "cart", "description": "Add a line item (product variant) to the cart"},
    {"method": "POST", "path": "/store/carts/:id/line-items/:line_id", "module": "cart", "description": "Update a line item quantity or metadata"},
    {"method": "DELETE", "path": "/store/carts/:id/line-items/:line_id", "module": "cart", "description": "Remove a line item from the cart"},
    {"method": "POST", "path": "/store/carts/:id/shipping-methods", "module": "cart", "description": "Add a shipping method to the cart"},
    {"method": "POST", "path": "/store/carts/:id/promotions", "module": "cart", "description": "Apply a promotion/discount code to the cart"},
    {"method": "DELETE", "path": "/store/carts/:id/promotions", "module": "cart", "description": "Remove a promotion code from the cart"},
    {"method": "POST", "path": "/store/carts/:id/complete", "module": "cart", "description": "Complete the cart and create an order"},
    {"method": "POST", "path": "/store/carts/:id/taxes", "module": "cart", "description": "Calculate taxes for the cart"},
    {"method": "GET", "path": "/store/products", "module": "product", "description": "List published products with filtering and pagination"},
    {"method": "GET", "path": "/store/products/:id", "module": "product", "description": "Get product details with variants, options, and prices"},
    {"method": "GET", "path": "/store/product-categories", "module": "product", "description": "List product categories in tree structure"},
    {"method": "GET", "path": "/store/product-categories/:id", "module": "product", "description": "Get category details with products"},
    {"method": "GET", "path": "/store/collections", "module": "product", "description": "List product collections"},
    {"method": "GET", "path": "/store/collections/:id", "module": "product", "description": "Get collection with products"},
    {"method": "GET", "path": "/store/orders", "module": "order", "description": "List authenticated customer's orders"},
    {"method": "GET", "path": "/store/orders/:id", "module": "order", "description": "Get order details for authenticated customer"},
    {"method": "GET", "path": "/store/customers/me", "module": "customer", "description": "Get authenticated customer profile"},
    {"method": "POST", "path": "/store/customers/me", "module": "customer", "description": "Update authenticated customer profile"},
    {"method": "POST", "path": "/store/customers", "module": "customer", "description": "Register a new customer account"},
    {"method": "GET", "path": "/store/customers/me/addresses", "module": "customer", "description": "List customer addresses"},
    {"method": "POST", "path": "/store/customers/me/addresses", "module": "customer", "description": "Add a new customer address"},
    {"method": "GET", "path": "/store/shipping-options", "module": "fulfillment", "description": "List available shipping options for a cart"},
    {"method": "GET", "path": "/store/regions", "module": "region", "description": "List available regions"},
    {"method": "GET", "path": "/store/regions/:id", "module": "region", "description": "Get region details with countries and providers"},
    {"method": "POST", "path": "/store/payment-collections", "module": "payment", "description": "Create a payment collection for checkout"},
    {"method": "POST", "path": "/store/payment-collections/:id/payment-sessions", "module": "payment", "description": "Initialize a payment session with a provider"},
    {"method": "POST", "path": "/store/payment-collections/:id/payment-sessions/:session_id/authorize", "module": "payment", "description": "Authorize a payment session"},
    {"method": "POST", "path": "/auth/:actor_type/:provider", "module": "auth", "description": "Authenticate (login) with email/password or social provider"},
    {"method": "POST", "path": "/auth/:actor_type/:provider/register", "module": "auth", "description": "Register a new auth identity"},
    {"method": "POST", "path": "/auth/token/refresh", "module": "auth", "description": "Refresh an expired JWT token"},
    {"method": "GET", "path": "/admin/orders", "module": "order", "description": "List all orders with filters and pagination"},
    {"method": "GET", "path": "/admin/orders/:id", "module": "order", "description": "Get full order details including fulfillments and payments"},
    {"method": "POST", "path": "/admin/orders/:id/fulfillments", "module": "order", "description": "Create a fulfillment for order items"},
    {"method": "POST", "path": "/admin/orders/:id/fulfillments/:fulfillment_id/shipments", "module": "order", "description": "Create a shipment with tracking number"},
    {"method": "POST", "path": "/admin/orders/:id/cancel", "module": "order", "description": "Cancel an order"},
    {"method": "POST", "path": "/admin/orders/:id/returns", "module": "order", "description": "Create a return for order items"},
    {"method": "POST", "path": "/admin/orders/:id/capture", "module": "order", "description": "Capture authorized payment on order"},
    {"method": "POST", "path": "/admin/orders/:id/refund", "module": "order", "description": "Issue a refund on a captured payment"},
    {"method": "GET", "path": "/admin/products", "module": "product", "description": "List all products with admin filters"},
    {"method": "POST", "path": "/admin/products", "module": "product", "description": "Create a new product with variants and options"},
    {"method": "POST", "path": "/admin/products/:id", "module": "product", "description": "Update product details"},
    {"method": "GET", "path": "/admin/inventory-items", "module": "inventory", "description": "List inventory items with stock levels"},
    {"method": "POST", "path": "/admin/inventory-items/:id/location-levels", "module": "inventory", "description": "Set inventory level for an item at a location"},
    {"method": "POST", "path": "/admin/payments/:id/capture", "module": "payment", "description": "Capture a payment"},
    {"method": "POST", "path": "/admin/payments/:id/refund", "module": "payment", "description": "Refund a payment"},
    {"method": "POST", "path": "/webhooks/payment/:provider", "module": "payment", "description": "Receive payment provider webhooks (Stripe, PayPal)"},
    {"method": "GET", "path": "/admin/customers", "module": "customer", "description": "List customers with search and filters"},
    {"method": "GET", "path": "/admin/price-lists", "module": "pricing", "description": "List price lists"},
    {"method": "POST", "path": "/admin/price-lists", "module": "pricing", "description": "Create a price list (sale, override)"},
    {"method": "POST", "path": "/admin/shipping-options", "module": "fulfillment", "description": "Create a shipping option with rules and pricing"},
    {"method": "GET", "path": "/admin/notifications", "module": "notification", "description": "List sent notifications"}
  ]
}
