# ============================================================
# AgentX SRE Triage Agent -- Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# === LLM ===
# Provider: "anthropic" (direct) or "openrouter" (supports multiple models)
LLM_PROVIDER=anthropic
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenRouter (alternative -- set LLM_PROVIDER=openrouter to use)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# === Database ===
# No changes needed -- works out of the box with Docker Compose
DATABASE_URL=postgresql+asyncpg://agentx:agentx@postgres:5432/agentx
POSTGRES_USER=agentx
POSTGRES_PASSWORD=agentx
POSTGRES_DB=agentx

# === Langfuse (LLM Observability) ===
# Option A (recommended): Langfuse Cloud -- sign up free at https://cloud.langfuse.com
# Option B: Self-hosted -- run: docker compose --profile self-hosted up --build
#           Then access at http://localhost:3000, create account, get keys from project settings
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
# Cloud: https://cloud.langfuse.com | Self-hosted: http://langfuse:3000
LANGFUSE_HOST=https://cloud.langfuse.com
# Self-hosted only (ignore if using Cloud):
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@langfuse-db:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=changeme-random-string-min-32-chars
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_SALT=changeme-random-salt-min-32-chars

# === Linear (Ticketing) ===
# Get your API key at: https://linear.app/settings/api
# Team ID: Go to Linear > Settings > Teams > click your team > copy ID from URL
# Leave empty to skip Linear integration (pipeline will still complete)
LINEAR_API_KEY=
LINEAR_TEAM_ID=
# Webhook secret: Set when creating a webhook in Linear > Settings > API > Webhooks
LINEAR_WEBHOOK_SECRET=
# Auto-assign P1/P2 tickets to this Linear user (get ID from Linear API or Settings > Members)
LINEAR_DEFAULT_ASSIGNEE_ID=

# === Slack (Team Notifications) ===
# Create a Slack app with incoming webhooks: https://api.slack.com/messaging/webhooks
# Create two webhook URLs pointing to different channels
# Leave empty to skip Slack integration (pipeline will still complete)
SLACK_WEBHOOK_CRITICAL=
SLACK_WEBHOOK_GENERAL=

# === Resend (Email Notifications) ===
# Get your API key at: https://resend.com/api-keys
# Leave empty to skip email integration (pipeline will still complete)
RESEND_API_KEY=
RESEND_FROM_EMAIL=incidents@yourdomain.com
RESEND_TEAM_EMAIL=oncall@yourdomain.com

# === LLM Model (override if using a specific model version) ===
# Only applies when LLM_PROVIDER=anthropic. OpenRouter uses OPENROUTER_MODEL instead.
LLM_MODEL=claude-sonnet-4-20250514

# === App ===
FRONTEND_URL=http://localhost:5173

# === Internal (set by Docker Compose -- no changes needed) ===
# UPLOAD_DIR=/app/uploads
# MEDUSA_REPO_PATH=/app/medusa-subset
# KNOWLEDGE_BASE_PATH=/app/knowledge-base
